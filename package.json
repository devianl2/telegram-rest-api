{
  "name": "telegram-api-server",
  "version": "1.0.0",
  "description": "Telegram API Server built with Fastify and TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts"
  },
  "dependencies": {
