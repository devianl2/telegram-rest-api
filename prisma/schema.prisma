// Run `prisma generate` after changing models.
// Run `prisma migrate dev` to apply schema changes to the database.
// To switch database engine, change the provider value and update DATABASE_URL in .env.
// Development: docker compose --profile development exec api-dev npx prisma migrate dev --name <migration_name>
// Production: docker compose --profile production exec api npx prisma migrate deploy


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TelegramSession {
  id          Int      @id @default(autoincrement())
  session_id  String   @db.Text
  server_name String   @db.VarChar(255)
  status      String   @db.VarChar(50)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("telegram_sessions")
}
