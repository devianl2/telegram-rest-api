# Development image: full install + dev server (no build)
# Do not use alpine base image for gramjs: https://github.com/gram-js/gramjs/issues/637
# Alpine uses musl libc which breaks GramJS's MTProto Diffie-Hellman key exchange
FROM node:22-slim

WORKDIR /app

COPY package*.json ./

RUN npm install

COPY tsconfig.json ./
COPY src ./src

EXPOSE 3000

CMD ["npm", "run", "dev"]
